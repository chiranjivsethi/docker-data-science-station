# Docker Data Science Station Environment Configuration
# Copy this file to .env and update with your own values
# cp .env.example .env

# ======================================
# SERVICE NAMES
# ======================================
# Main Services
SERVICE_INIT_DIRS=init-dirs
SERVICE_JUPYTERLAB=jupyterlab
SERVICE_MINIO=minio
SERVICE_POSTGRES=postgres
SERVICE_MLFLOW=mlflow
SERVICE_DASHBOARD=dashboard

# Airflow Services
SERVICE_REDIS=redis
SERVICE_AIRFLOW_APISERVER=airflow-apiserver
SERVICE_AIRFLOW_SCHEDULER=airflow-scheduler
SERVICE_AIRFLOW_DAG_PROCESSOR=airflow-dag-processor
SERVICE_AIRFLOW_WORKER=airflow-worker
SERVICE_AIRFLOW_TRIGGERER=airflow-triggerer
SERVICE_AIRFLOW_INIT=airflow-init
SERVICE_AIRFLOW_CLI=airflow-cli
SERVICE_AIRFLOW_FLOWER=flower
SERVICE_INIT_AIRFLOW_DIRS=init-airflow-dirs

# ======================================
# DASHBOARD AND SERVICES
# ======================================
BASE_URL=http://your-server-ip # Base URL for accessing services else it defaults to http://localhost

# ======================================
# JUPYTER LAB
# ======================================
# Security token for JupyterLab access
JUPYTER_TOKEN=your_secure_token_here

# Directory to mount into JupyterLab container
RESEARCH_DIR=/path/to/your/research/data

HOST_PORT=8888

# ======================================
# MINIO (Object Storage)
# ======================================
# Root user credentials for MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_password_here

# Directory for MinIO data persistence
MINIO_DATA_DIR=/path/to/minio/data

# ======================================
# POSTGRESQL
# ======================================
# PostgreSQL superuser credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Default database name
POSTGRES_DB=research_db

# Directory for PostgreSQL data persistence
POSTGRES_DATA_DIR=/path/to/postgres/data

# ======================================
# APACHE AIRFLOW
# ======================================
# Airflow UID (should match your user UID on Linux)
AIRFLOW_UID=1000

# Airflow Docker image version
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.0

# Airflow web UI credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=your_secure_password_here

# FERNET_KEY for encrypting Airflow connections and variables (generate with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
FERNET_KEY=your_fernet_key_here #if not set, Airflow will generate one automatically but it won't persist across restarts

# JWT authentication settings
AIRFLOW__API_AUTH__JWT_SECRET=your_jwt_secret_here
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# Airflow directories
AIRFLOW_HOME=/path/to/airflow
AIRFLOW_DAGS_DIR=/path/to/airflow/dags
AIRFLOW_LOGS_DIR=/path/to/airflow/logs
AIRFLOW_CONFIG_DIR=/path/to/airflow/config
AIRFLOW_PLUGINS_DIR=/path/to/airflow/plugins

# ======================================
# MLFLOW
# ======================================
MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:latest
MLFLOW_PORT=5000
MLFLOW_DB_NAME=mlflow_db
MLFLOW_BACKEND_STORE_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${MLFLOW_DB_NAME}
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow-artifacts
MLFLOW_SERVER_ALLOWED_HOSTS=*
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_TRACKING_URI=http://mlflow:5000
