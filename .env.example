# Docker Data Science Station Environment Configuration
# Copy this file to .env and update with your own values
# cp .env.example .env

# ======================================
# DASHBOARD AND SERVICES
# ======================================
BASE_URL=http://your-server-ip # Base URL for accessing services else it defaults to http://localhost

# ======================================
# JUPYTER LAB
# ======================================
# Security token for JupyterLab access
JUPYTER_TOKEN=your_secure_token_here

# Directory to mount into JupyterLab container
RESEARCH_DIR=/path/to/your/research/data

HOST_PORT=8888

# ======================================
# MINIO (Object Storage)
# ======================================
# Root user credentials for MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_password_here

# Directory for MinIO data persistence
MINIO_DATA_DIR=/path/to/minio/data

# ======================================
# POSTGRESQL
# ======================================
# PostgreSQL superuser credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Default database name
POSTGRES_DB=research_db

# Directory for PostgreSQL data persistence
POSTGRES_DATA_DIR=/path/to/postgres/data

# ======================================
# APACHE AIRFLOW
# ======================================
# Airflow UID (should match your user UID on Linux)
AIRFLOW_UID=1000

# Airflow Docker image version
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.0

# Airflow web UI credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=your_secure_password_here

# JWT authentication settings
AIRFLOW__API_AUTH__JWT_SECRET=your_jwt_secret_here
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# Airflow directories
AIRFLOW_HOME=/path/to/airflow
AIRFLOW_DAGS_DIR=/path/to/airflow/dags
AIRFLOW_LOGS_DIR=/path/to/airflow/logs
AIRFLOW_CONFIG_DIR=/path/to/airflow/config
AIRFLOW_PLUGINS_DIR=/path/to/airflow/plugins
